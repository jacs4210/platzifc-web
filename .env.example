# =============================================
# Platzi FC — Variables de Entorno
# Copia este archivo como .env.local en cada app
# NUNCA subas .env.local a Git
# =============================================

# ──────────────────────────────
# Supabase (Free Tier)
# Obtener en: https://app.supabase.com → Settings → API
# ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ──────────────────────────────
# MongoDB Atlas M0 (Free Forever)
# Obtener en: https://cloud.mongodb.com → Connect → Drivers
# ──────────────────────────────
MONGODB_URI=mongodb+srv://platzifc:<password>@cluster0.xxxxx.mongodb.net/platzifc?retryWrites=true&w=majority

# ──────────────────────────────
# Upstash Redis (Free: 10k cmd/día)
# Obtener en: https://console.upstash.com → Redis → REST API
# ──────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token-here

# ──────────────────────────────
# Upstash Kafka (Free: 10 GB/mes)
# Obtener en: https://console.upstash.com → Kafka → Cluster details
# ──────────────────────────────
UPSTASH_KAFKA_REST_URL=https://xxxxx.upstash.io
UPSTASH_KAFKA_REST_USERNAME=your-kafka-username
UPSTASH_KAFKA_REST_PASSWORD=your-kafka-password

# ──────────────────────────────
# API Football (Free: 100 req/día)
# Obtener en: https://rapidapi.com/api-sports/api/api-football
# ──────────────────────────────
API_FOOTBALL_KEY=your-api-football-key-here

# ──────────────────────────────
# Resend — Email Transaccional (Free: 3k emails/mes)
# Obtener en: https://resend.com → API Keys
# ──────────────────────────────
RESEND_API_KEY=re_your-resend-key-here

# ──────────────────────────────
# Stripe (sin costo hasta primera venta)
# Obtener en: https://dashboard.stripe.com → Developers → API Keys
# ──────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# ──────────────────────────────
# MercadoPago (Free API)
# Obtener en: https://developers.mercadopago.com
# ──────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=TEST-your-access-token-here

# ──────────────────────────────
# URLs de las apps (desarrollo local)
# ──────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SHOP_URL=http://localhost:3001
NEXT_PUBLIC_TICKETS_URL=http://localhost:3002
NODE_ENV=development
