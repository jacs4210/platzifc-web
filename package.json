{
  "name": "platzifc-web",
  "version": "0.0.1",
  "private": true,
  "description": "Platzi FC Web Platform — Monorepo",
  "author": "jacs4210",
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "build": "pnpm --filter './packages/*' build && pnpm --filter './apps/*' build",
    "lint": "pnpm --recursive lint",
    "typecheck": "pnpm --recursive typecheck",
    "test": "pnpm --recursive test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "clean": "pnpm --recursive clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@platzifc/eslint-config": "workspace:*",
    "@platzifc/ts-config": "workspace:*",
    "prettier": "^3.3.3",
    "turbo": "^2.3.0",
    "typescript": "^5.5.0"
  }
}
